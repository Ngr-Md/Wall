<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ir.aut.ap.wall.client.controller.HomeController">
    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="16" right="16" top="16"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="welcomeLabel" styleClass="title-label" text="خوش اومدی!"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#onCreateAd" styleClass="primary-button" text="+ آگهی جدید"/>
                <Button onAction="#onMyAds" styleClass="secondary-button" text="آگهی‌ هام"/>
                <Button onAction="#onFavorites" styleClass="secondary-button" text="نشان هام"/>
                <Button onAction="#onConversations" styleClass="secondary-button" text="چت هام"/>
                <Button fx:id="adminButton" onAction="#onAdmin" styleClass="secondary-button" text="پنل ادمین"/>
                <Button onAction="#onLogout" styleClass="secondary-button" text="خروج"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <TextField fx:id="searchField" promptText="جستجو در عنوان و توضیحات..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="categoryCombo" promptText="دسته‌بندی"/>
                <ComboBox fx:id="cityCombo" promptText="شهر"/>
                <TextField fx:id="minPriceField" prefWidth="110" promptText="حداقل قیمت"/>
                <TextField fx:id="maxPriceField" prefWidth="110" promptText="حداکثر قیمت"/>
                <ComboBox fx:id="sortCombo" promptText="مرتب‌سازی"/>
                <Button onAction="#onSearch" styleClass="primary-button" text="جستجو"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="ads-scroll">
            <FlowPane fx:id="adsFlowPane" hgap="16" vgap="16">
                <padding>
                    <Insets bottom="24" left="16" right="16" top="8"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>
</BorderPane>
