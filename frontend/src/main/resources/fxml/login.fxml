<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ir.aut.ap.marketplace.client.controller.LoginController">
    <VBox alignment="CENTER" maxWidth="420" spacing="14" styleClass="card">
        <padding>
            <Insets bottom="30" left="30" right="30" top="30"/>
        </padding>
        <Label styleClass="title-label" text="WALL"/>
        <Label styleClass="subtitle-label" text="برو تو حساب"/>
        <TextField fx:id="usernameField" promptText="یوزرنیمت یادته؟"/>
        <PasswordField fx:id="passwordField" promptText="رمزت چی بود؟"/>
        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>
        <Button maxWidth="Infinity" onAction="#onLogin" styleClass="primary-button" text="برو تو"/>
        <Hyperlink onAction="#onGoToRegister" text="اگر حساب نداری اینو بزن!"/>
    </VBox>
</StackPane>
