<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ir.aut.ap.wall.client.controller.CreateAdController">
    <VBox maxWidth="560" spacing="12" styleClass="card">
        <padding>
            <Insets bottom="24" left="24" right="24" top="24"/>
        </padding>
        <Label fx:id="headerLabel" styleClass="title-label" text="ثبت آگهی جدید"/>
        <TextField fx:id="titleField" promptText="تایتل آگهیت"/>
        <TextArea fx:id="descriptionArea" prefRowCount="5" promptText="یه توضیحی هم بده چی داری میفروشی" wrapText="true"/>
        <TextField fx:id="priceField" promptText="قیمت (چندرغاز)"/>
        <HBox spacing="8">
            <ComboBox fx:id="categoryCombo" promptText="دسته‌بندی" HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="cityCombo" promptText="شهر" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Button onAction="#onAddImage" styleClass="secondary-button" text="عکس گذاشتن"/>
            <Button onAction="#onClearImages" styleClass="secondary-button" text="همه ی عکسا رو پاک کن!"/>
            <Label fx:id="imagesLabel" text="عکس نذاشتیا!"/>
        </HBox>
        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>
        <HBox spacing="8">
            <Button onAction="#onSubmit" styleClass="primary-button" text="حله"/>
            <Button onAction="#onBack" styleClass="secondary-button" text="کنسله"/>
        </HBox>
    </VBox>
</StackPane>
